{
  "name": "llm-armor",
  "version": "0.2.0",
  "description": "Bulletproof LLM output — validation, auto-retry, type coercion, and fallback chains for TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "ai",
    "validation",
    "structured-output",
    "openai",
    "anthropic",
    "gemini",
    "zod",
    "retry",
    "fallback",
    "type-safe",
    "json-repair"
  ],
  "author": "Satyamtechy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Satyamtechy/llm-armor"
  },
  "peerDependencies": {
    "zod": ">=3.22.0"
  },
  "devDependencies": {
    "tsup": "8.4.0",
    "tsx": "^4.22.3",
    "typescript": "5.7.3",
    "vitest": "3.0.4",
    "zod": "3.24.1"
  }
}
